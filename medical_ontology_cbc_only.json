{
  "version": "1.0",
  "scope": "cbc_only",
  "description": "CBC-only ontology for fallback scoring when Stage-1 marks a case as NOT CBC-related or Stage-2 confidence is low.",
  "global_disclaimer": "Clinical decision support only. Not a diagnosis. Always correlate with symptoms, exam, and confirmatory tests.",
  "scoring": {
    "method": "weighted_rule_match",
    "score_formula": "sum(weights of matched rules) / sum(weights of all rules)",
    "default_min_score": 0.3,
    "notes": [
      "Only CBC-related conditions are included.",
      "If a feature is not supplied, its rule remains unmatched.",
      "Features may be inferred from values or optional cbc_flags."
    ]
  },
  "cbc_related": {
    "healthy": {
      "display_name": "Healthy",
      "min_score": 0.75,
      "pattern_rules": [
        {
          "id": "hb_normal",
          "feature": "hemoglobin",
          "direction": "normal",
          "weight": 0.2,
          "reason": "Hemoglobin within normal range supports a healthy CBC pattern."
        },
        {
          "id": "mcv_normal",
          "feature": "mcv",
          "direction": "normal",
          "weight": 0.15,
          "reason": "MCV within normal range supports normal red cell size."
        },
        {
          "id": "mch_normal",
          "feature": "mch",
          "direction": "normal",
          "weight": 0.1,
          "reason": "MCH within normal range supports normal hemoglobin content per cell."
        },
        {
          "id": "mchc_normal",
          "feature": "mchc",
          "direction": "normal",
          "weight": 0.1,
          "reason": "MCHC within normal range supports normal hemoglobin concentration."
        },
        {
          "id": "wbc_normal",
          "feature": "wbc",
          "direction": "normal",
          "weight": 0.15,
          "reason": "WBC within normal range supports absence of major leukocyte abnormality."
        },
        {
          "id": "rbc_normal",
          "feature": "rbc",
          "direction": "normal",
          "weight": 0.1,
          "reason": "RBC within normal range supports a healthy pattern."
        },
        {
          "id": "hct_normal",
          "feature": "hematocrit",
          "direction": "normal",
          "weight": 0.1,
          "reason": "Hematocrit within normal range supports normal red cell volume fraction."
        },
        {
          "id": "differential_normal",
          "feature": "differential",
          "direction": "normal",
          "weight": 0.1,
          "reason": "No major differential abnormality supports a healthy pattern."
        }
      ],
      "likely_causes": [
        "Physiologic/normal CBC pattern"
      ],
      "confirmatory_tests": [],
      "suggested_specialty": {
        "name": "Primary Care",
        "reason": "No specific specialty referral if clinically well."
      },
      "red_flags": []
    },
    "iron_deficiency_anemia": {
      "display_name": "Iron deficiency anemia",
      "min_score": 0.4,
      "pattern_rules": [
        {
          "id": "hb_low",
          "feature": "hemoglobin",
          "direction": "low",
          "weight": 0.25,
          "reason": "Low hemoglobin supports anemia."
        },
        {
          "id": "mcv_low",
          "feature": "mcv",
          "direction": "low",
          "weight": 0.25,
          "reason": "Low MCV supports microcytosis."
        },
        {
          "id": "mch_low",
          "feature": "mch",
          "direction": "low",
          "weight": 0.2,
          "reason": "Low MCH supports hypochromia."
        },
        {
          "id": "mchc_low_or_normal",
          "feature": "mchc",
          "direction": "low_or_normal",
          "weight": 0.1,
          "reason": "MCHC may be low or near-normal in iron deficiency."
        },
        {
          "id": "rbc_low_or_normal",
          "feature": "rbc",
          "direction": "low_or_normal",
          "weight": 0.1,
          "reason": "RBC count is often low or normal."
        },
        {
          "id": "hct_low",
          "feature": "hematocrit",
          "direction": "low",
          "weight": 0.1,
          "reason": "Low hematocrit supports anemia severity."
        }
      ],
      "likely_causes": [
        "Chronic blood loss",
        "Poor dietary iron intake",
        "Malabsorption",
        "Increased iron demand"
      ],
      "confirmatory_tests": [
        {
          "test": "Ferritin",
          "priority": 1,
          "reason": "Best initial test for iron stores."
        },
        {
          "test": "Serum iron",
          "priority": 2,
          "reason": "Supports iron deficiency workup."
        },
        {
          "test": "TIBC",
          "priority": 2,
          "reason": "Helps interpret iron status."
        },
        {
          "test": "Transferrin saturation",
          "priority": 2,
          "reason": "Refines iron deficiency assessment."
        },
        {
          "test": "Peripheral smear",
          "priority": 3,
          "reason": "Looks for microcytosis/hypochromia."
        }
      ],
      "suggested_specialty": {
        "name": "Hematology",
        "reason": "For persistent, severe, or unclear anemia."
      },
      "red_flags": [
        "Very low hemoglobin",
        "Syncope, dyspnea, chest pain",
        "Possible active bleeding"
      ]
    },
